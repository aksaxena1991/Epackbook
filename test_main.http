### ------------------------------------------------------------------
### Base variables
### ------------------------------------------------------------------
@baseUrl = http://127.0.0.1:8000/
@contentType = application/json

### ------------------------------------------------------------------
### Health check / root
### ------------------------------------------------------------------
GET {{baseUrl}}/
Accept: {{contentType}}

###

### ------------------------------------------------------------------
### Create Auth User
### ------------------------------------------------------------------
POST {{baseUrl}}/auth/
Content-Type: {{contentType}}

{
  "email": "testuser1@example.com",
  "password": "StrongPassword@123",
  "mobile": "9999999991"
}

###

### ------------------------------------------------------------------
### Create Auth User (duplicate email → should FAIL with 409)
### ------------------------------------------------------------------
POST {{baseUrl}}/auth/
Content-Type: {{contentType}}

{
  "email": "testuser1@example.com",
  "password": "AnotherPassword@123",
  "mobile": "9999999992"
}

###

### ------------------------------------------------------------------
### Get Auth User by ID
### Replace 1 with actual ID returned from create
### ------------------------------------------------------------------
GET {{baseUrl}}/auth/1
Accept: {{contentType}}

###

### ------------------------------------------------------------------
### Get Auth User (non-existing → 404)
### ------------------------------------------------------------------
GET {{baseUrl}}/auth/9999
Accept: {{contentType}}

###

### ------------------------------------------------------------------
### Update Auth User (password + mobile)
### ------------------------------------------------------------------
PUT {{baseUrl}}/auth/1
Content-Type: {{contentType}}

{
  "password": "UpdatedPassword@123",
  "mobile": "8888888888"
}

###

### ------------------------------------------------------------------
### Deactivate Auth User
### ------------------------------------------------------------------
PUT {{baseUrl}}/auth/1
Content-Type: {{contentType}}

{
  "is_active": false
}

###

### ------------------------------------------------------------------
### Delete Auth User
### ------------------------------------------------------------------
DELETE {{baseUrl}}/auth/1
Accept: {{contentType}}

###

### ------------------------------------------------------------------
### Get Deleted User (should be 404)
### ------------------------------------------------------------------
GET {{baseUrl}}/auth/1
Accept: {{contentType}}

###